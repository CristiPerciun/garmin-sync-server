# Copia come .env e compila. NON commitare .env!
# === GARMIN ===
GARMIN_EMAIL=
GARMIN_PASSWORD=

# === FIREBASE ===
USER_ID=

# === CONFIG ===
GARTH_HOME=./garth_tokens
SYNC_INTERVAL_MINUTES=45

# Per cron esterno (opzionale): cron-job.org chiama POST /internal/scheduled-sync ogni 45 min
# Se non impostato, l'endpoint accetta qualsiasi richiesta (solo per dev locale)
CRON_SECRET=

# Firebase su Pi: usa UNA riga FIREBASE_CREDENTIALS_B64 (systemd EnvironmentFile non gestisce bene JSON multilinea).
# Genera: scripts/rpi_setup/encode_firebase_credentials_b64.ps1 oppure sul Pi: base64 -w0 < firebase.json
# Verifica sul Pi: python3 deploy/rpi/verify_firebase_credentials.py
# FIREBASE_CREDENTIALS_B64=...
# opzionale (dev): FIREBASE_CREDENTIALS={"type":"service_account",...}   # una sola riga

# Timeout RPC Firestore in secondi (hotspot/rete lenta verso Google; default 120)
# FIRESTORE_TIMEOUT_SEC=120

# Porta HTTP (default 8080; systemd RPI usa 8080)
# PORT=8080
