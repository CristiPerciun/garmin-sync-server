# Copia come .env e compila. NON commitare .env!
# === GARMIN ===
GARMIN_EMAIL=
GARMIN_PASSWORD=

# === FIREBASE ===
USER_ID=

# === CONFIG ===
GARTH_HOME=./garth_tokens
SYNC_INTERVAL_MINUTES=45

# Per cron esterno (opzionale): cron-job.org chiama POST /internal/scheduled-sync ogni 45 min
# Se non impostato, l'endpoint accetta qualsiasi richiesta (solo per dev locale)
CRON_SECRET=

# Firebase su Pi / Render: preferisci base64 (evita problemi con virgolette)
# FIREBASE_CREDENTIALS_B64=<output di: [Convert]::ToBase64String([IO.File]::ReadAllBytes("firebase-service-account.json")) su Windows>
# oppure FIREBASE_CREDENTIALS={"type":"service_account",...}

# Porta HTTP (default 8080; systemd RPI usa 8080)
# PORT=8080
