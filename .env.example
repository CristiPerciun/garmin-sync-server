# Copia come .env e compila. NON commitare .env!
# === GARMIN ===
GARMIN_EMAIL=
GARMIN_PASSWORD=

# === FIREBASE ===
USER_ID=

# === CONFIG ===
# Opzionale: solo se hai esportato oauth1/oauth2 in questa cartella. Se la cartella è vuota,
# garth.Client() crasha: lascia commentato o rimuovi (il server usa token su Firestore).
# GARTH_HOME=./garth_tokens
SYNC_INTERVAL_MINUTES=45

# Per cron esterno (opzionale): cron-job.org chiama POST /internal/scheduled-sync ogni 45 min
# Se non impostato, l'endpoint accetta qualsiasi richiesta (solo per dev locale)
CRON_SECRET=

# Firebase su Pi: usa UNA riga FIREBASE_CREDENTIALS_B64 (systemd EnvironmentFile non gestisce bene JSON multilinea).
# Genera: scripts/rpi_setup/encode_firebase_credentials_b64.ps1 oppure sul Pi: base64 -w0 < firebase.json
# Verifica sul Pi: python3 deploy/rpi/verify_firebase_credentials.py
# FIREBASE_CREDENTIALS_B64=...
# opzionale (dev): FIREBASE_CREDENTIALS={"type":"service_account",...}   # una sola riga

# Timeout RPC Firestore in secondi (hotspot/rete lenta verso Google; default 120)
# FIRESTORE_TIMEOUT_SEC=120

# Porta HTTP (default 8080; systemd RPI usa 8080)
# PORT=8080

# Opzionale: stesso valore di GARMIN_SERVER_BEARER_TOKEN nell'app Flutter
# GARMIN_SERVER_BEARER_TOKEN=

# Strava lato server (register-tokens / delta / backfill) — stessi client_id/secret dell'app OAuth
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=

# Backfill dopo connect/register-tokens (giorni) e batch attività Garmin per finestra date
# BACKFILL_DAYS=60
# GARMIN_BACKFILL_BATCH_DAYS=10

# Dopo 429 su sso.garmin.com: minuti senza nuovi tentativi login (salvato su users/{uid})
# GARMIN_SSO_BACKOFF_MINUTES=25
# Ritardo avvio backfill dopo login OK (secondi) — separa SSO da burst API verso Garmin
# GARMIN_BACKFILL_AFTER_CONNECT_DELAY_SEC=90
